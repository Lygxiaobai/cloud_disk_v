# Copy to .env.docker before running docker compose.

# Public HTTP port published by nginx
HTTP_PORT=80

# MySQL
MYSQL_DATABASE=cloud_disk
MYSQL_USER=cloud_disk
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Redis
REDIS_PASSWORD=

# RabbitMQ
# Leave as-is unless you enable the optional rabbitmq profile.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# JWT
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-hex-32

# SMTP
# Leave empty if you do not need registration email verification.
MAIL_FROM=
MAIL_HOST=
MAIL_SERVER_NAME=
MAIL_USERNAME=
MAIL_PASSWORD=

# OSS
# Leave empty if you do not need upload/preview.
OSS_REGION=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ROLE_ARN=
OSS_EXTERNAL_ID=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

