#!/usr/bin/env bash
set -euo pipefail

zero_commit="0000000000000000000000000000000000000000"

is_sensitive_path() {
  case "$1" in
    .env|.env.*|*.pem|*.key|*.p12|*.pfx|*.crt|*.cer|*.jks|*.keystore|id_rsa|id_rsa.pub|id_ed25519|id_ed25519.pub|*.secret|*.secrets|service-account*.json|credentials*.json|secrets*.json|.npmrc)
      return 0
      ;;
  esac
  return 1
}

scan_commit_range() {
  local range="$1"
  local failed=0
  local path
  local added_diff

  while IFS= read -r path; do
    [ -n "$path" ] || continue

    if is_sensitive_path "$path"; then
      echo "Push blocked: sensitive file path detected: $path" >&2
      failed=1
    fi
  done < <(git diff --name-only --diff-filter=AMR "$range")

  while IFS= read -r path; do
    [ -n "$path" ] || continue

    added_diff="$(git diff --no-color --unified=0 "$range" -- "$path" | grep -E '^\+[^+]' || true)"

    if printf '%s\n' "$added_diff" | grep -Eiq \
      'AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|ghp_[0-9A-Za-z]{36,}|github_pat_[0-9A-Za-z_]{20,}|sk_(live|test)_[0-9A-Za-z]{16,}|xox[baprs]-[0-9A-Za-z-]{10,}|-----BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY-----|(api[_-]?key|secret|token|password)[[:space:]]*[:=][[:space:]]*["'\'']?[^"'\''[:space:]]{8,}'; then
      echo "Push blocked: possible secret detected in $path" >&2
      failed=1
    fi
  done < <(git diff --name-only --diff-filter=AM "$range")

  return "$failed"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_sha:-}" ] || continue

  if [ "$local_sha" = "$zero_commit" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_commit" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if ! scan_commit_range "$range"; then
    echo "Remove the secret from the push, rotate it if it was real, then retry." >&2
    exit 1
  fi
done
