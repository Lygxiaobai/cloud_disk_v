{
  "name": "cloud-disk-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "format": "prettier --write \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \".eslintrc.cjs\" \"src/main.ts\"",
    "format:check": "prettier --check \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \".eslintrc.cjs\" \"src/main.ts\""
  },
  "dependencies": {
    "@types/spark-md5": "^3.0.5",
    "ali-oss": "^6.23.0",
    "axios": "^1.7.9",
    "element-plus": "^2.9.7",
    "pinia": "^2.3.1",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^5.4.11",
    "vue-tsc": "^2.2.0"
  }
}
