# 云盘项目环境变量模板
# 使用方式：
#   1. 复制为 .env （项目根目录）
#   2. 填写真实值
#   3. 启动前 source .env 或 使用 dotenv 工具加载到环境变量
#
# 所有带 ${VAR} 的 core-api.yaml 占位符都从这里取值。

# ---- JWT 密钥（生产必须重新生成：openssl rand -hex 32） ----
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-32bytes
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-32bytes

# ---- 数据库 ----
MYSQL_DSN=root:123456@(127.0.0.1:3306)/cloud_disk?charset=utf8mb4&parseTime=True&loc=Local

# ---- Redis ----
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ---- 邮箱（SMTP） ----
MAIL_FROM=18163688304@163.com
MAIL_USERNAME=18163688304@163.com
MAIL_PASSWORD=

# ---- 阿里云 OSS ----
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
