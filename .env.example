# Cloud Disk environment template
# Copy this file to `.env`, then replace the placeholder values.

# JWT
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-hex-32

# MySQL
MYSQL_DSN=cloud_disk:replace-with-strong-password@tcp(127.0.0.1:3306)/cloud_disk?charset=utf8mb4&parseTime=True&loc=Local

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# SMTP
# Leave these empty if you do not need registration email verification.
MAIL_FROM=
MAIL_HOST=
MAIL_SERVER_NAME=
MAIL_USERNAME=
MAIL_PASSWORD=

# OSS
# Leave these empty if you do not need upload/preview.
OSS_REGION=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ROLE_ARN=
OSS_EXTERNAL_ID=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
